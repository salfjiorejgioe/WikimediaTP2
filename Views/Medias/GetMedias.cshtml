@model IEnumerable<Models.Media>

@{
    var currentUserId = Models.User.ConnectedUser.Id;
    bool isAdmin = Models.User.ConnectedUser.Access == Models.Access.Admin;
}

@if (Model != null && Model.Any())
{
    foreach (var media in Model)
    {
        if (media.Shared || media.OwnerId == currentUserId || isAdmin)
        {
            var user = media.Owner;

            <div class="mediaLayout">
                <a href="/Medias/Details/@media.Id" title="Voir les détails de @media.Title" style="text-decoration:none; width:100% !important">
                    <div class="mediaThumbnail"
                         style="background-image:url('https://img.youtube.com/vi/@media.YoutubeId/mqdefault.jpg');padding:6px; display:flex; flex-flow:row-reverse;">

                        <div class="UserSmallAvatar transparentBackground"
                             style="background: url('@user.Avatar'); border:0.1px solid white;">
                        </div>

                        @if (media.Shared && media.OwnerId == currentUserId)
                        {
                            <img src="~/Content/ui-images/shared.png" class="UserSmallAvatar transparentBackground" alt="Partagé">
                        }
                    </div>
                </a>

                <div class="ellipsis" style="margin-left: 4px; margin-right: 4px; font-size: 0.8em; font-weight: bold">
                    @media.Title
                </div>

                <div style="margin-left: 4px; color: gray; font-size: 0.65em">
                    @media.Category <br />
                    @Helper.When(media.PublishDate)
                </div>
            </div>
        }
    }
}
else
{
    <h3>Aucun résultat</h3>
}